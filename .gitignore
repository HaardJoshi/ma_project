*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/

# ─── Virtual environments ───────────────────────────────────────────
env/
venv/
.venv/

# ─── IDE ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store

